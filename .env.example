# App
PORT=3000
NODE_ENV=development

# Postgres (single instance, one schema per module)
DATABASE_URL=postgres://payment:payment@localhost:5432/payment_backend

# Redis (used for pub/sub + idempotency cache)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Stripe (use test-mode keys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Event bus impl: "memory" (EventEmitter2, default) or "redis" (Redis pub/sub)
EVENT_BUS_DRIVER=memory

# Outbox publisher poll interval (ms)
OUTBOX_POLL_INTERVAL_MS=1000

# Fulfillment simulation: how long an order stays in "preparing" before
# transitioning to "shipped", and how often the shipper poller runs.
FULFILLMENT_PREPARING_DELAY_SECONDS=10
FULFILLMENT_POLL_INTERVAL_MS=2000

# Apple Pay: paste the single-line contents Stripe gives you in
# Dashboard -> Payment methods -> Apple Pay -> Add domain. Leaving this unset
# makes the /.well-known/... endpoint return 404 (the default for local dev).
APPLE_PAY_DOMAIN_ASSOCIATION=
